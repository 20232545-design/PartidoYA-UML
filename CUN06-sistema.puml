@startuml "Gestionar suscripciones"
left to right direction
skinparam usecase {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam actor {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
}
skinparam Arrow {
  Color #7A1631
}

actor "Jugador" as Jugador
actor "Administrador de Cancha" as Admin
actor "Pasarela Culqi" as Culqi

rectangle "Sistema PartidoYA - [Módulo Suscripciones]" {
  usecase "Iniciar Sesión" as Login
  usecase "Adquirir Plan Jugador Plus\n<<Release 02>>" as CUS_PlanJugador
  usecase "Adquirir Plan Cancha Comercial\n<<Release 02>>" as CUS_PlanCancha
  usecase "Visualizar Beneficios y Reportes\n<<Release 02>>" as CUS_VerBeneficios
}

Jugador -- CUS_PlanJugador
Jugador -- CUS_VerBeneficios
Admin -- CUS_PlanCancha
Admin -- CUS_VerBeneficios

CUS_PlanJugador ..> Login : <<include>>
CUS_PlanCancha ..> Login : <<include>>
CUS_VerBeneficios ..> Login : <<include>>

CUS_PlanJugador -- Culqi
CUS_PlanCancha -- Culqi
@enduml