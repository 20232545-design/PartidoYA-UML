@startuml
title PartidoYA - Modelo de Base de Datos 



!pragma layout smetana

left to right direction

hide methods
hide circle

skinparam linetype polyline
skinparam packageStyle rectangle
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam nodesep 80
skinparam ranksep 100

skinparam package {
  BorderThickness 2
  FontStyle bold
}

skinparam class {
  BorderThickness 1
}


package "Perfil / IAM Bounded Context" as BC_PERFIL <<Bounded Context>> {

  enum RolUsuario {
    JUGADOR
    ADMIN_CANCHA
    ADMIN_SISTEMA
  }

  enum EstadoUsuario {
    ACTIVO
    SUSPENDIDO
    ELIMINADO
  }

  enum NivelDeportivo {
    PRINCIPIANTE
    INTERMEDIO
    AVANZADO
  }

  class Usuario <<table>> {
    id_usuario: BIGINT <<PK>>
    correo: VARCHAR(150) <<UQ>>
    rol: RolUsuario
    estado: EstadoUsuario
    correo_verificado: BOOLEAN
    fecha_registro: DATETIME
  }

  class Credencial <<table>> {
    id_credencial: BIGINT <<PK>>
    id_usuario: BIGINT <<FK, UQ>>
    password_hash: VARCHAR(255)
    ultimo_acceso: DATETIME
    intentos_fallidos: INT
    fecha_actualizacion: DATETIME
  }

  class PerfilUsuario <<table>> {
    id_perfil: BIGINT <<PK>>
    id_usuario: BIGINT <<FK, UQ>>
    nombre: VARCHAR(100)
    apellido: VARCHAR(100)
    telefono: VARCHAR(20)
    foto_perfil_url: VARCHAR(255)
    fecha_actualizacion: DATETIME
  }

  class Deporte <<table>> {
    id_deporte: BIGINT <<PK>>
    nombre: VARCHAR(80) <<UQ>>
    descripcion: VARCHAR(255)
    activo: BOOLEAN
  }

  class PreferenciaDeportiva <<table>> {
    id_preferencia: BIGINT <<PK>>
    id_perfil: BIGINT <<FK>>
    id_deporte: BIGINT <<FK>>
    nivel: NivelDeportivo
    es_favorito: BOOLEAN
  }

  Usuario "1" -down- "1" Credencial : posee
  Usuario "1" -right- "1" PerfilUsuario : tiene

  PerfilUsuario "1" -down- "0..*" PreferenciaDeportiva : configura
  Deporte "1" -right- "0..*" PreferenciaDeportiva : corresponde a


}


package "Partido Bounded Context" as BC_PARTIDO <<Bounded Context>> {

  enum NivelPartido {
    PRINCIPIANTE
    INTERMEDIO
    AVANZADO
    MIXTO
  }

  enum EstadoPartido {
    BORRADOR
    ABIERTO
    COMPLETO
    CANCELADO
    FINALIZADO
  }

  enum EstadoParticipacion {
    CONFIRMADA
    CANCELADA
    EN_ESPERA
    ASISTIO
    NO_ASISTIO
  }

  enum EstadoReporte {
    PENDIENTE
    REVISADO
    DESCARTADO
    SANCIONADO
  }

  class Partido <<table>> {
    id_partido: BIGINT <<PK>>
    id_organizador: BIGINT <<FK>>
    id_deporte: BIGINT <<FK>>
    id_cancha: BIGINT <<FK>>
    titulo: VARCHAR(120)
    descripcion: VARCHAR(255)
    fecha: DATE
    hora_inicio: TIME
    hora_fin: TIME
    direccion_referencia: VARCHAR(255)
    cupos_totales: INT
    nivel_requerido: NivelPartido
    estado: EstadoPartido
    fecha_creacion: DATETIME
  }

  class Participacion <<table>> {
    id_participacion: BIGINT <<PK>>
    id_partido: BIGINT <<FK>>
    id_usuario: BIGINT <<FK>>
    estado: EstadoParticipacion
    fecha_union: DATETIME
    fecha_actualizacion: DATETIME
  }

  class Calificacion <<table>> {
    id_calificacion: BIGINT <<PK>>
    id_partido: BIGINT <<FK>>
    id_usuario_calificador: BIGINT <<FK>>
    id_usuario_calificado: BIGINT <<FK>>
    puntaje: SMALLINT
    comentario: VARCHAR(255)
    fecha_calificacion: DATETIME
  }

  class ReporteUsuario <<table>> {
    id_reporte: BIGINT <<PK>>
    id_usuario_reportante: BIGINT <<FK>>
    id_usuario_reportado: BIGINT <<FK>>
    id_partido: BIGINT <<FK>>
    motivo: VARCHAR(150)
    descripcion: VARCHAR(500)
    estado: EstadoReporte
    fecha_reporte: DATETIME
    fecha_revision: DATETIME
  }


  Partido "1" -right- "0..*" Participacion : registra
  Partido "1" -down- "0..*" Calificacion : contextualiza

  Partido "0..1" -down- "0..*" ReporteUsuario : contextualiza


}


package "Reserva Bounded Context" as BC_RESERVA <<Bounded Context>> {

  enum EstadoCancha {
    ACTIVA
    INACTIVA
    MANTENIMIENTO
  }

  enum DiaSemana {
    LUN
    MAR
    MIE
    JUE
    VIE
    SAB
    DOM
  }

  enum EstadoReserva {
    PENDIENTE
    CONFIRMADA
    CANCELADA
    VENCIDA
  }

  enum MetodoPagoReserva {
    YAPE
    PLIN
    TARJETA
    EFECTIVO
  }

  enum EstadoPagoReserva {
    PENDIENTE
    PAGADO
    RECHAZADO
    DEVUELTO
  }

  class Cancha <<table>> {
    id_cancha: BIGINT <<PK>>
    id_administrador: BIGINT <<FK>>
    nombre: VARCHAR(120)
    descripcion: VARCHAR(255)
    direccion: VARCHAR(255)
    distrito: VARCHAR(100)
    latitud: DECIMAL(10,8)
    longitud: DECIMAL(11,8)
    precio_hora: DECIMAL(10,2)
    estado: EstadoCancha
    fecha_registro: DATETIME
  }

  class HorarioDisponible <<table>> {
    id_horario: BIGINT <<PK>>
    id_cancha: BIGINT <<FK>>
    dia_semana: DiaSemana
    hora_inicio: TIME
    hora_fin: TIME
    disponible: BOOLEAN
  }

  class BloqueoHorario <<table>> {
    id_bloqueo: BIGINT <<PK>>
    id_cancha: BIGINT <<FK>>
    fecha: DATE
    hora_inicio: TIME
    hora_fin: TIME
    motivo: VARCHAR(255)
    fecha_creacion: DATETIME
  }

  class ReservaCancha <<table>> {
    id_reserva: BIGINT <<PK>>
    id_cancha: BIGINT <<FK>>
    id_partido: BIGINT <<FK, UQ>>
    id_usuario_reservante: BIGINT <<FK>>
    fecha_reserva: DATE
    hora_inicio: TIME
    hora_fin: TIME
    estado: EstadoReserva
    monto_total: DECIMAL(10,2)
    fecha_creacion: DATETIME
  }

  class PagoReserva <<table>> {
    id_pago_reserva: BIGINT <<PK>>
    id_reserva: BIGINT <<FK>>
    id_usuario: BIGINT <<FK>>
    monto: DECIMAL(10,2)
    metodo: MetodoPagoReserva
    estado: EstadoPagoReserva
    codigo_transaccion: VARCHAR(120)
    comprobante_url: VARCHAR(255)
    fecha_pago: DATETIME
  }

  Cancha "1" -right- "0..*" HorarioDisponible : dispone de
  Cancha "1" -down- "0..*" BloqueoHorario : bloquea

  Cancha "1" -right- "0..*" ReservaCancha : recibe
  ReservaCancha "1" -down- "0..*" PagoReserva : registra




package "Suscripción Bounded Context" as BC_SUSCRIPCION <<Bounded Context>> {

  enum TipoPlan {
    JUGADOR
    ADMIN_CANCHA
  }

  enum PeriodicidadPlan {
    MENSUAL
    TRIMESTRAL
    ANUAL
  }

  enum EstadoSuscripcion {
    PENDIENTE
    ACTIVA
    VENCIDA
    CANCELADA
    SUSPENDIDA
  }

  enum MetodoPagoSuscripcion {
    TARJETA
    YAPE
    PLIN
  }

  enum EstadoPagoSuscripcion {
    PENDIENTE
    PAGADO
    RECHAZADO
    DEVUELTO
  }

  class PlanSuscripcion <<table>> {
    id_plan: BIGINT <<PK>>
    nombre: VARCHAR(100)
    descripcion: VARCHAR(255)
    tipo: TipoPlan
    periodicidad: PeriodicidadPlan
    precio: DECIMAL(10,2)
    activo: BOOLEAN
  }

  class Suscripcion <<table>> {
    id_suscripcion: BIGINT <<PK>>
    id_usuario: BIGINT <<FK>>
    id_plan: BIGINT <<FK>>
    estado: EstadoSuscripcion
    fecha_inicio: DATE
    fecha_fin: DATE
    renovacion_automatica: BOOLEAN
    fecha_creacion: DATETIME
  }

  class PagoSuscripcion <<table>> {
    id_pago_suscripcion: BIGINT <<PK>>
    id_suscripcion: BIGINT <<FK>>
    monto: DECIMAL(10,2)
    metodo: MetodoPagoSuscripcion
    estado: EstadoPagoSuscripcion
    codigo_transaccion: VARCHAR(120)
    fecha_pago: DATETIME
  }


  PlanSuscripcion "1" -right- "0..*" Suscripcion : define
  Suscripcion "1" -down- "0..*" PagoSuscripcion : registra


}



package "Notificación Bounded Context" as BC_NOTIFICACION <<Bounded Context>> {

  enum TipoNotificacion {
    PARTIDO
    RESERVA
    PAGO
    SUSCRIPCION
    REPORTE
    SISTEMA
  }

  class Notificacion <<table>> {
    id_notificacion: BIGINT <<PK>>
    id_usuario: BIGINT <<FK>>
    titulo: VARCHAR(120)
    mensaje: VARCHAR(500)
    tipo: TipoNotificacion
    referencia_id: BIGINT
    leida: BOOLEAN
    fecha_envio: DATETIME
    fecha_lectura: DATETIME
  }
}



Usuario "1" -right- "0..*" Partido : organiza
Usuario "1" -right- "0..*" Participacion : participa

Deporte "1" -right- "0..*" Partido : clasifica

Usuario "1" -right- "0..*" Calificacion : calificador
Usuario "1" -right- "0..*" Calificacion : calificado

Usuario "1" -right- "0..*" ReporteUsuario : reportante
Usuario "1" -right- "0..*" ReporteUsuario : reportado



Usuario "1" -right- "0..*" Cancha : administra
Usuario "1" -right- "0..*" ReservaCancha : reserva
Usuario "1" -right- "0..*" PagoReserva : realiza


Partido "1" -right- "0..1" ReservaCancha : origina
Cancha "1" -left- "0..*" Partido : sirve como sede



Usuario "1" -right- "0..*" Suscripcion : contrata



Usuario "1" -right- "0..*" Notificacion : recibe


@enduml
