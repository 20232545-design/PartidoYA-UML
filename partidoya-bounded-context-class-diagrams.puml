@startuml "PartidoYA - Class Diagram by Bounded Context"
skinparam linetype ortho
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam packageStyle rectangle

left to right direction

package "IAM / Profile Bounded Context" {

  class User {
    +id: Long
    +email: String
    +status: UserStatus
    +role: UserRole
    +registrationDate: DateTime
    +activateAccount()
    +deactivateAccount()
  }

  class Credential {
    +id: Long
    +passwordHash: String
    +lastLogin: DateTime
    +changePassword()
    +validatePassword()
  }

  class UserProfile {
    +id: Long
    +fullName: String
    +phoneNumber: String
    +profilePictureUrl: String
    +updateProfile()
  }

  class SportPreference {
    +id: Long
    +skillLevel: SkillLevel
    +isPrimary: Boolean
  }

  class Sport {
    +id: Long
    +name: String
    +description: String
  }

  enum UserRole {
    PLAYER
    ORGANIZER
    COURT_ADMIN
  }

  enum UserStatus {
    PENDING
    ACTIVE
    BLOCKED
  }

  enum SkillLevel {
    BEGINNER
    INTERMEDIATE
    ADVANCED
  }

  User "1" -- "1" Credential
  User "1" -- "1" UserProfile
  UserProfile "1" -- "0..*" SportPreference
  SportPreference "*" -- "1" Sport
}

package "Match Bounded Context" {

  class Match {
    +id: Long
    +title: String
    +date: Date
    +startTime: Time
    +endTime: Time
    +status: MatchStatus
    +create()
    +publish()
    +cancel()
    +closeRegistration()
  }

  class MatchCapacity {
    +playerLimit: Integer
    +availableSlots: Integer
    +reserveSlot()
    +releaseSlot()
    +isAvailable(): Boolean
  }

  class Participation {
    +id: Long
    +registrationDate: DateTime
    +status: ParticipationStatus
    +confirm()
    +cancel()
  }

  class UserReference {
    +userId: Long
    +displayName: String
  }

  class SportReference {
    +sportId: Long
    +name: String
  }

  class CourtReference {
    +courtId: Long
    +name: String
    +address: String
  }

  enum MatchStatus {
    DRAFT
    OPEN
    FULL
    CANCELLED
    FINISHED
  }

  enum ParticipationStatus {
    CONFIRMED
    CANCELLED
    WAITING
  }

  Match "1" *-- "1" MatchCapacity
  Match "1" -- "0.." Participation
  Match "1" --> "1" UserReference : organizer
  Match "1" --> "1" SportReference
  Match "1" --> "1" CourtReference
  Participation "*" --> "1" UserReference : player
}

package "Reservation Bounded Context" {

  class Court {
    +id: Long
    +name: String
    +address: String
    +district: String
    +pricePerHour: Decimal
    +status: CourtStatus
    +updateCourt()
    +disableCourt()
  }

  class AvailableSchedule {
    +id: Long
    +dayOfWeek: String
    +startTime: Time
    +endTime: Time
    +isAvailable: Boolean
  }

  class Reservation {
    +id: Long
    +date: Date
    +startTime: Time
    +endTime: Time
    +status: ReservationStatus
    +confirm()
    +cancel()
    +validateAvailability()
  }

  class ScheduleBlock {
    +id: Long
    +date: Date
    +startTime: Time
    +endTime: Time
    +reason: String
    +activateBlock()
  }

  class CourtAdminReference {
    +userId: Long
    +name: String
  }

  class MatchReference {
    +matchId: Long
    +title: String
  }

  enum CourtStatus {
    ACTIVE
    INACTIVE
    MAINTENANCE
  }

  enum ReservationStatus {
    PENDING
    CONFIRMED
    CANCELLED
    EXPIRED
  }

  Court "1" -- "1" CourtAdminReference
  Court "1" -- "0.." AvailableSchedule
  Court "1" -- "0.." ScheduleBlock
  Court "1" -- "0..*" Reservation
  Reservation "*" --> "1" MatchReference
}

package "Subscription Bounded Context" {

  class SubscriptionPlan {
    +id: Long
    +name: String
    +description: String
    +price: Decimal
    +durationDays: Integer
    +matchLimit: Integer
    +createPlan()
    +updatePlan()
  }

  class Subscription {
    +id: Long
    +startDate: Date
    +endDate: Date
    +status: SubscriptionStatus
    +activate()
    +cancel()
    +renew()
  }

  class Payment {
    +id: Long
    +amount: Decimal
    +paymentDate: DateTime
    +paymentMethod: PaymentMethod
    +status: PaymentStatus
    +registerPayment()
    +confirmPayment()
  }

  class SubscriberReference {
    +userId: Long
    +email: String
  }

  enum SubscriptionStatus {
    ACTIVE
    EXPIRED
    CANCELLED
    PENDING_PAYMENT
  }

  enum PaymentMethod {
    CARD
    YAPE
    PLIN
    BANK_TRANSFER
  }

  enum PaymentStatus {
    PENDING
    APPROVED
    REJECTED
    REFUNDED
  }

  SubscriberReference "1" -- "0..*" Subscription
  Subscription "*" --> "1" SubscriptionPlan
  Subscription "1" -- "0.." Payment
}

@enduml
