@startuml "Reportar jugadores"
left to right direction
skinparam usecase {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam actor {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
}
skinparam Arrow {
  Color #7A1631
}

actor "Jugador" as Jugador

rectangle "Sistema PartidoYA - [Módulo Moderación y Reputación]" {
  usecase "Iniciar Sesión" as Login
  usecase "Registrar Reporte de Jugador\n<<Release 02>>" as CUS_Reportar
  usecase "Calificar Participante Post-Partido\n<<Release 02>>" as CUS_Calificar
}

Jugador -- CUS_Reportar
Jugador -- CUS_Calificar

CUS_Reportar ..> Login : <<include>>
CUS_Calificar ..> Login : <<include>>
@enduml