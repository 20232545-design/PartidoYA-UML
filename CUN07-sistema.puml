@startuml "CUS07 - Comunidad Negocios"
left to right direction
skinparam usecase {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
}
skinparam actor {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
}
skinparam Arrow {
  Color #7A1631
}

actor "Jugador" as Jugador

rectangle "Sistema PartidoYA - [Módulo Social y Reputación]" {
  usecase "Iniciar Sesión" as Login
  usecase "Ingresar al Chat del Partido" as CUS_Chat
  usecase "Calificar a los Jugadores" as CUS_Calificar
  usecase "Enviar Solicitudes de Amistad" as CUS_Amigos
  usecase "Ingresar al Portal de Estadísticas\ny Sistema de Endorsement" as CUS_Endorsement
}


Jugador -- CUS_Chat
Jugador -- CUS_Calificar
Jugador -- CUS_Amigos
Jugador -- CUS_Endorsement


CUS_Chat ..> Login : <<include>>
CUS_Calificar ..> Login : <<include>>
CUS_Amigos ..> Login : <<include>>
CUS_Endorsement ..> Login : <<include>>
@enduml