@startuml "Buscar compañeros de deporte"
left to right direction
skinparam usecase {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam actor {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
}
skinparam Arrow {
  Color #7A1631
}

actor "Jugador" as Jugador
actor "Google Maps API" as Maps

rectangle "Sistema PartidoYA - [Módulo Matchmaking]" {
  usecase "Iniciar Sesión" as Login
  usecase "Buscar Partidos Disponibles" as CUS_Buscar
  usecase "Unirse a Partido\n(Reservar Vacante)" as CUS_Unirse
}

Jugador -- CUS_Buscar
Jugador -- CUS_Unirse

CUS_Buscar ..> Login : <<include>>
CUS_Unirse ..> Login : <<include>>
CUS_Buscar -- Maps
@enduml