@startuml "Components-Bounded Contexts"
!includeurl https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title PartidoYA - Component Diagram (Bounded Contexts)

Container(spa, "Single Page Application", "Angular", "Provee toda la funcionalidad de búsqueda de partidos, gestión de perfil y reservas al navegador del usuario")
ContainerDb(db, "Base de Datos", "MySQL", "Almacena información de usuarios, partidos, canchas, reservas y suscripciones")

Container_Boundary(api, "API Application") {
    Component(partido, "Partido", "Gestión completa del ciclo de vida de partidos: creación, inscripción, confirmación y cancelación")
    Component(perfil, "Perfil", "Gestión de perfiles de jugadores y administradores, preferencias deportivas y reputación")
    Component(reserva, "Reserva", "Gestión de reservas de canchas, disponibilidad de horarios y confirmación de espacios")
    Component(suscripcion, "Suscripción", "Gestión de planes de suscripción, pagos recurrentes y beneficios")
    Component(iam, "IAM", "Gestión de identidad, autenticación y autorización de usuarios")
    Component(shared, "Shared", "Componentes y utilidades transversales compartidas entre bounded contexts")
}

Rel(spa, partido, "Crea, busca y gestiona partidos")
Rel(spa, perfil, "Gestiona perfiles de usuarios")
Rel(spa, reserva, "Reserva y consulta disponibilidad de canchas")
Rel(spa, suscripcion, "Gestiona suscripciones y pagos")
Rel(spa, iam, "Autentica y autoriza usuarios")

Rel(partido, perfil, "Verifica datos del jugador y obtiene preferencias deportivas")
Rel(partido, reserva, "Consulta disponibilidad y reserva ambientes deportivos")
Rel(reserva, suscripcion, "Valida beneficios de suscripción para descuentos")
Rel(perfil, iam, "Valida identidad y permisos del usuario")

Rel(partido, shared, "Usa utilidades comunes")
Rel(perfil, shared, "Usa utilidades comunes")
Rel(reserva, shared, "Usa utilidades comunes")
Rel(suscripcion, shared, "Usa utilidades comunes")
Rel(iam, shared, "Usa utilidades comunes")

Rel(partido, db, "Lee y escribe datos de partidos")
Rel(perfil, db, "Lee y escribe datos de perfiles")
Rel(reserva, db, "Lee y escribe datos de reservas")
Rel(suscripcion, db, "Lee y escribe datos de suscripciones")
Rel(iam, db, "Lee y escribe credenciales de usuarios")

@enduml
