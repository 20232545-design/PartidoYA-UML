@startuml
title PartidoYA - Diagrama de Secuencia: Crear partido

skinparam backgroundColor transparent
skinparam sequence {
    ArrowColor #1F3851
    ActorBorderColor #1F3851
    LifeLineBorderColor #1F3851
    LifeLineBackgroundColor #F5F5F5
    ParticipantBorderColor #1F3851
    ParticipantBackgroundColor #EAF2F8
    DatabaseBorderColor #497676
    DatabaseBackgroundColor #E8F6F3
}

autonumber

actor Organizador
boundary "Angular SPA\nFormulario de partido" as Frontend
control "PartidoController" as Controller
control "CrearPartidoService\nPartido BC" as Service
entity "PartidoRepository" as Repository
database "PartidoYA_DB" as DB

Organizador -> Frontend: Accede a «Crear pichanga»
Frontend --> Organizador: Mostrar formulario

Organizador -> Frontend: Ingresa deporte, ubicación,\nfecha, hora y número de jugadores
Organizador -> Frontend: Selecciona «Publicar partido»

Frontend -> Frontend: Validar campos obligatorios

alt Campos incompletos
    Frontend --> Organizador: Resaltar campos obligatorios
else Campos completos
    Frontend -> Controller: POST /api/partidos\n(datos del partido, token JWT)
    activate Controller

    Controller -> Service: crearPartido(datos, idOrganizador)
    activate Service

    Service -> Service: Validar fecha y hora

    alt Fecha u hora pasada
        Service --> Controller: Error de validación
        Controller --> Frontend: HTTP 400 Bad Request
        Frontend --> Organizador: Mostrar fecha u hora inválida
    else Fecha válida
        Service -> Service: Crear entidad Partido\nestado = ABIERTO

        Service -> Repository: guardar(partido)
        activate Repository

        Repository -> DB: INSERT INTO partidos
        activate DB
        DB --> Repository: Partido registrado
        deactivate DB

        Repository --> Service: Partido creado
        deactivate Repository

        Service --> Controller: Datos del partido
        Controller --> Frontend: HTTP 201 Created
        Frontend --> Organizador: Mostrar confirmación de publicación
    end

    deactivate Service
    deactivate Controller
end

@enduml
